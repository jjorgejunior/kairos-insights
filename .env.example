# Copie este arquivo para ".env" (dev local) e preencha com sua chave real.
# NUNCA prefixe com VITE_ — isso embutiria a chave no bundle do navegador.
# Em produção, defina GEMINI_API_KEY como variável de ambiente/secret no
# painel de deploy (Cloudflare, Vercel, Netlify, etc.), nunca neste arquivo.
GEMINI_API_KEY=
